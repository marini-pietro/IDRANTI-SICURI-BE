# Python compiled files & Cache
# Don't include compiled Python bytecode
__pycache__
*.py[cod]        # .pyc, .pyo, .pyd files
*.so              # Compiled extension modules

# pytest and testing cache
.pytest_cache
.coverage
htmlcov/
*.egg-info/
dist/
build/

# Virtual environments (development only)
# No need in Docker as dependencies are installed during build
venv/
env/
.venv
.env
.env.local
*.egg

# Version control & configuration management
.git              # Git repository
.gitignore        # Git config
.gitattributes    # Git config
.github/          # GitHub workflows/actions
.gitlab-ci.yml    # GitLab CI config
.dockerignore     # This file itself

# IDE & Editor Configuration
# Exclude development tool configs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store        # macOS metadata
Thumbs.db        # Windows thumbnail cache
*.sublime-project
*.sublime-workspace

# Project specific files
# Logs and temp files generated during development
*log.txt
*.log
logs/
tmp/
temp/
*.tmp

# Test files
tests/
*_test.py
test_*.py
conftest.py

# Documentation
docs/
*.md
README.md

# Development scripts
developing_scripts/
*.ps1
*.sh

# Node/JavaScript artifacts
node_modules/
npm-debug.log
yarn-error.log

# Database files
# (intermediary SQLite database files are handled in named volumes so they are persistent across container events)
*.db
*.sqlite
*.sqlite3

# OS-specific files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db