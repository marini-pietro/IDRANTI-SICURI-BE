# Before starting the application, make sure to set up to remove the .example suffix.
#
# Before committing any changes to the codebase, make sure to properly include .env files in your .gitignore to avoid leaking sensitive information.
# Some configurations (not dependant on environment) have to remain in *_config.py and cannot be set here because they are of complex types.
# The *_config.py files using the built-in get function also declares a default value for each setting, which is used if no value is set in this .env file, these values are usually only suitable for development environments.
# To configure some settings, like the sql regex pattern or PBKDF2HMAC settings, directly editing config.py is required.
# In most cases, any mantainer or developer can do the vast majority of the configuration just by changing the settings in this .env file.
# Checking and understanding the settings in config.py is, nonetheless, still strongly recommended.

# --- API server settings ---
API_SERVER_HOST=0.0.0.0 # host to run the API server on [Must be '0.0.0.0' for Docker purposes so the container listens on all interfaces (for Docker Compose)]
API_SERVER_PORT=5000 # port to run the API server on
API_SERVER_IDENTIFIER=api-server-1 # identifier of the API server (used to distinguish multiple api servers if needed) (will show up in logs and will be passed to logging interface)
API_VERSION=v1 # version of the API
API_SERVER_DEBUG_MODE=False # enable/disable debug mode for flask built-in server (required to be False to simulate production environment) (see production_scripts/README.txt) [DOCKER: Changed from True to False for containerized deployment]
API_SERVER_RUN_ENV=development # environment for the API server (production/development) (used to distinguish between different environments if needed)
API_SERVER_RATE_LIMIT=True # enable/disable rate limiting on the API server
API_SERVER_MAX_JSON_SIZE=51220 # max size of incoming JSON payload in bytes
SQL_SCAN_MAX_LEN=2048 # max length of a string to be scanned for SQL injection
SQL_SCAN_MAX_RECURSION_DEPTH=10 # max recursion depth when scanning nested objects for SQL injection
# (a limit must be set to avoid DoS attacks with specially crafted payloads that cause infinite recursion/very deep recursion or, in general, excessive resource consumption)
IS_AUTH_SERVER_SSL=False # whether the authentication server uses SSL/TLS or not (has to match the settings of the auth server)

API_SERVER_SSL_CERT="" # path to SSL certificate file (leave empty to disable SSL)
# IF EMPTY BE SURE TO INSERT DOUBLE QUOTES, OTHERWISE THE COMMENT WILL BE INTERPRETED AS THE VALUE
API_SERVER_SSL_KEY="" # path to SSL key file (leave empty to disable SSL) 
# IF EMPTY BE SURE TO INSERT DOUBLE QUOTES, OTHERWISE THE COMMENT WILL BE INTERPRETED AS THE VALUE

API_SERVER_LOG_INTERFACE_DB_FILENAME="" # path to the sqlite database file used by the logging interface
# (in most cases it is recommended to leave this empty and let the interface create a database file with a more accurate name based on runtime data such as timestamps)
# db filename must end with .db
# db file will be created in idranti-sicuri-logs subdirectory

# --- Authentication server settings ---
AUTH_SERVER_HOST=0.0.0.0 # host to run the auth server on [Must be '0.0.0.0' for Docker purposes so the container listens on all interfaces (for Docker Compose)]
AUTH_SERVER_PORT=5001 # port to run the auth server on
AUTH_SERVER_IDENTIFIER=auth-server-1 # identifier of the auth server (used to distinguish multiple auth servers if needed) will show up in logs and will be passed to logging interface)
AUTH_SERVER_DEBUG_MODE=False # enable/disable debug mode for flask built-in server (required to be False to simulate production environment) (see production_scripts/README.txt) [DOCKER: Changed from True to False for containerized deployment]
AUTH_SERVER_RUN_ENV=development # environment for the auth server (production/development) (used to distinguish between different environments if needed)
AUTH_SERVER_RATE_LIMIT=True # enable/disable rate limiting on the auth server
AUTH_API_VERSION=v1 # version of the API exposed by the authentication server
JWT_VALIDATION_CACHE_SIZE=1000 # number of cached JWT validation results
JWT_VALIDATION_CACHE_TTL=3600 # in seconds

AUTH_SERVER_SSL_CERT="" # path to SSL certificate file (leave empty to disable SSL) 
# IF EMPTY BE SURE TO INSERT DOUBLE QUOTES, OTHERWISE THE COMMENT WILL BE INTERPRETED AS THE VALUE
AUTH_SERVER_SSL_KEY="" # path to SSL key file (leave empty to disable SSL) 
# IF EMPTY BE SURE TO INSERT DOUBLE QUOTES, OTHERWISE THE COMMENT WILL BE INTERPRETED AS THE VALUE

AUTH_SERVER_LOG_INTERFACE_DB_FILENAME="" # path to the sqlite database file used by the logging interface
# (in most cases it is recommended to leave this empty and let the interface create a database file with a more accurate name based on runtime data such as timestamps)
# db filename must end with .db
# db file will be created in idranti-sicuri-logs subdirectory

# --- JWT related settings ---
JWT_SECRET_KEY=Lorem ipsum dolor sit amet eget. # secret key used to sign the JWT [DOCKER: SECURITY - Must change this in production!]
JWT_ALGORITHM=HS256 # algorithm used to sign the JWT
JWT_QUERY_STRING_NAME=jwt_token # name of the query string parameter where to look for the JWT
JWT_JSON_KEY=jwt_token # key in json where to find the access token
JWT_REFRESH_JSON_KEY=jwt_refresh_token # key in json where to find the refresh token
JWT_TOKEN_LOCATION=headers,query_string,json # where to look for the JWT (values have to be comma separated with no spaces)
JWT_REFRESH_TOKEN_EXPIRES_DAYS=10 # days until a refresh token expires
JWT_ACCESS_TOKEN_EXPIRES_HOURS=3 # hours until an access token expires

# --- Log server settings ---
LOG_SERVER_HOST=0.0.0.0 # host to run the log server on [Must be '0.0.0.0' for Docker purposes so the container listens on all interfaces (for Docker Compose)]
LOG_SERVER_PORT=514 # port to run the log server on (514 is the standard syslog port for UDP communication)
LOG_SERVER_IDENTIFIER=log-server-1 # identifier of the log server (used to distinguish multiple log servers if needed) (also the name that shows up in logs)
LOG_FILE_NAME=idranti-sicuri_log.txt # name of the log file
LOGGER_NAME=idranti-sicuri_logger # name of the logger
LOG_SERVER_RATE_LIMIT=True # enable/disable rate limiting on the log server
DELAYED_LOGS_QUEUE_SIZE=100 # size of the queue for delayed logs
RETAIN_LOGS_RATE_LIMIT_TRIGGER=True # whether or not to retain logs (but not process them immediately) when rate limit is triggered (see 3rd point in Rate limiting section of README.md)
LOG_RATE_LIMIT_TRIGGER_EVENTS=True # whether or not to log rate limit trigger events (log that an ip has been rate limited)
# log server has no SSL configuration because it is strictly a syslog server (i.e. it does not have an HTTP interface and only receives UDP packets)
# log server has no debug mode

# --- Log server rate limiting settings ---
LOG_SERVER_RATE_LIMIT_MAX_REQUESTS=50 # max number of requests
# For service names the identifiers of the servers sending logs to the log server will be used
LOG_SERVER_RATE_LIMIT_CACHE_SIZE=1000 # size of the cache for rate limiting
LOG_SERVER_RATE_LIMIT_CACHE_TTL=10 # in seconds

# --- Logging interface settings ---
LOG_INTERFACE_DB_FILENAME="" # path to the sqlite database file used by the logging interface
# (in most cases it is recommended to leave this empty and let the interface create a database 
# file with a more accurate name based on runtime data such as timestamps)
# db filename must end with .db
# db file will be created in idranti-sicuri-logs subdirectory
LOG_INTERFACE_MAX_RETRIES=5 # max number of retries to send a log message via UDP
LOG_INTERFACE_BATCH_DELAY=15 # delay between batches of logs sent to the log server by the logging interface

# --- Database/ORM settings ---
DB_HOST=db # database host [Must be 'db' (to match the service/container name in docker-compose.yml) for inter-container communication; this is the hostname, NOT the database name]
DB_NAME=postgres # database name
DB_USER=postgres # database user
DB_PASSWORD=postgres # database password [DOCKER: SECURITY - Use strong password in production instead of placeholder]
DB_PORT=5432 # database port
# Used by docker-compose.yml for DATABASE_URL environment variable
# Example: postgresql://postgres:postgres@db:5432/postgres
DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

SQLALCHEMY_TRACK_MODIFICATIONS=False # whether to track modifications of objects and emit signals
# (will have major performance impact, recommended to keep it disabled)

# --- Rate limiting settings ---
RATE_LIMIT_MAX_REQUESTS=50 # max number of requests
RATE_LIMIT_CACHE_SIZE=1000 # size of the cache for rate limiting
RATE_LIMIT_CACHE_TTL=10 # in seconds